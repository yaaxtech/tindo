{
  "name": "tindo",
  "version": "0.0.1",
  "private": true,
  "description": "TinDo — produtividade por swipe, com IA, gamificação e neurociência.",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "cf:build": "next build && bunx opennextjs-cloudflare build && cp .open-next/worker.js .open-next/assets/_worker.js",
    "cf:preview": "wrangler dev .open-next/worker.js --local",
    "cf:deploy": "bunx wrangler deploy",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "PWDEBUG=1 playwright test",
    "db:types": "bunx supabase gen types typescript --project-id jtpfauouvbtmhgrszybk > src/types/database.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.456.0",
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "tailwind-merge": "^2.5.4",
    "tone": "^15.0.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@opennextjs/cloudflare": "^1.19.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.9.0",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.12",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "postgres": "^3.4.9",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
  }
}
